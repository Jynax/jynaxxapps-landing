# Copy this file to .env and fill in real values for local dev.
# In Cloudflare Pages, set these as build/runtime environment variables.

# Google OAuth client ID for the admin sign-in flow.
# Get this from https://console.cloud.google.com -> APIs & Services -> Credentials.
# OAuth client IDs are public-safe; the client *secret* is what stays private.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
